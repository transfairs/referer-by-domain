{
  "manifest_version": 3,
  "name": "Referer By Domain",
  "description": "Set referer type per domain. The intention is to mock the behaviour of network.http.sendRefererHeader for individual domains.",
  "version": "1.0",
  "author": "Robin Trauer",
  "icons": {
    "16": "icons/gear-16x16.png",
    "48": "icons/gear-48x48.png",
    "128": "icons/gear-128x128.png"
  },
  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "tabs",
    "storage",
    "activeTab"
  ],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Referer By Domain",
    "default_icon": {
      "16": "icons/gear-16x16.png",
      "32": "icons/gear-32x32.png",
      "48": "icons/gear-48x48.png"
    }
  },
  "background": {
    "scripts": ["js/background.js"],
    "type": "module"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "resources": [
        "resources/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
